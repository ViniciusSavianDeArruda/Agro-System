generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Inventory {
  id       String @id @default(uuid())
  userId   String
  item     String
  quantity Int
  user     User   @relation(fields: [userId], references: [id])
}

model Task {
  id          String   @id @default(uuid())
  userId      String
  description String
  date        DateTime
  completed   Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id])
}

model Expense {
  id           String     @id
  plantationId String
  description  String
  amount       Float
  date         DateTime
  Plantation   Plantation @relation(fields: [plantationId], references: [id])
}

model Harvest {
  id           String     @id
  plantationId String
  revenue      Float
  date         DateTime
  Plantation   Plantation @relation(fields: [plantationId], references: [id])
}

model Plantation {
  id      String    @id
  name    String
  userId  String
  Expense Expense[]
  Harvest Harvest[]
  User    User      @relation(fields: [userId], references: [id])
}

model User {
  id          String       @id
  name        String
  email       String       @unique
  password    String
  inventories Inventory[]
  Plantation  Plantation[]
  tasks       Task[]
}
